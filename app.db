CREATE TABLE users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    pseudo VARCHAR(50) NOT NULL UNIQUE
);

CREATE TABLE genres (
    name VARCHAR(50) NOT NULL UNIQUE
);


CREATE TABLE animes (
    id INT AUTO_INCREMENT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    synopsis TEXT,
    status ENUM('en cours', 'termine', 'annule') DEFAULT 'en cours'
);

CREATE TABLE anime_genres (
    anime_id INT,
    genre_id INT,
    PRIMARY KEY (anime_id, genre_name),
    FOREIGN KEY (anime_id) REFERENCES animes(id) ON DELETE CASCADE,
    FOREIGN KEY (genre_name) REFERENCES genres(name) ON DELETE CASCADE
);


CREATE TABLE user_anime_list (
    user_id INT,
    anime_id INT,
    score INT CHECK (score >= 0 AND score <= 10),
    user_status ENUM('a regarder', 'en cours', 'termine'),
    PRIMARY KEY (user_id, anime_id),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (anime_id) REFERENCES animes(id) ON DELETE CASCADE
);

